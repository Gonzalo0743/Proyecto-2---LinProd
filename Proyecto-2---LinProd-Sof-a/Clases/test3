"""
Prueba batch de Etapa 3 — verifica MotorCiclos, breakpoints y reporte.
No requiere input del usuario.
"""
import sys, os
sys.path.insert(0, os.path.dirname(__file__))

from lineaproduccion import LineaDeProduccion
from proceso import Proceso
from tarea import Tarea
from simulador import Simulador
from motorciclos import MotorCiclos
from reporte import Reporte


def construir_linea():
    linea = LineaDeProduccion()
    pA = Proceso("Corte",   es_inicial=True)
    pA.agregar_tarea(Tarea("Corte-1", 2))
    pA.agregar_tarea(Tarea("Corte-2", 3))
    linea.agregar_proceso(pA)

    pB = Proceso("Pintura")
    pB.agregar_tarea(Tarea("Pintura", 4))
    pB.agregar_tarea(Tarea("Secado",  2))
    linea.agregar_proceso(pB)

    pC = Proceso("Empaque",  es_final=True)
    pC.agregar_tarea(Tarea("Empaque",  2))
    pC.agregar_tarea(Tarea("Despacho", 1))
    linea.agregar_proceso(pC)

    linea.enlazar_procesos()
    return linea


def test_motor_batch():
    print("── TEST 1: Motor batch (sin delay) ──────────────────────")
    sim = Simulador(construir_linea())
    sim.iniciar(5)
    motor = MotorCiclos(sim, velocidad=0)
    ciclos = motor.correr_batch()
    assert sim.esta_terminado(), "Error: no todos los productos terminaron"
    assert len(sim.productos_completados) == 5
    print(f"  OK — 5 productos completados en {ciclos} ciclos")


def test_breakpoint():
    print("\n── TEST 2: Breakpoint automático en ciclo 5 ─────────────")
    import threading, time
    sim = Simulador(construir_linea())
    sim.iniciar(5)
    motor = MotorCiclos(sim, velocidad=0)
    motor.agregar_breakpoint(5)

    pausas = []
    def on_pausa(s):
        pausas.append(s.ciclo_actual)

    motor.on_pausa(on_pausa)
    motor.correr_en_hilo()

    # Esperar hasta que pause (máx 3s)
    t0 = time.time()
    while not motor.esta_pausado() and time.time() - t0 < 3:
        time.sleep(0.01)

    assert motor.esta_pausado(), "Error: el motor no se pausó en el breakpoint"
    assert sim.ciclo_actual == 5, f"Error: esperaba ciclo 5, got {sim.ciclo_actual}"
    print(f"  OK — motor pausado automáticamente en ciclo {sim.ciclo_actual}")

    motor.reanudar()
    t0 = time.time()
    while motor.esta_corriendo() and time.time() - t0 < 5:
        time.sleep(0.01)

    assert sim.esta_terminado(), "Error: simulación no terminó tras reanudar"
    print(f"  OK — simulación terminó tras reanudar ({sim.ciclo_actual} ciclos totales)")


def test_snapshot():
    print("\n── TEST 3: Snapshot en ciclo específico ─────────────────")
    sim = Simulador(construir_linea())
    sim.iniciar(3)
    motor = MotorCiclos(sim, velocidad=0)
    motor.agregar_breakpoint(4)
    motor.correr_en_hilo()

    import time
    t0 = time.time()
    while not motor.esta_pausado() and time.time() - t0 < 3:
        time.sleep(0.01)

    snap = sim.get_snapshot()
    assert snap["ciclo"] == 4
    print(f"  OK — snapshot capturado en ciclo {snap['ciclo']}")
    sim.imprimir_snapshot()

    motor.reanudar()
    while motor.esta_corriendo():
        time.sleep(0.01)


def test_reporte():
    print("\n── TEST 4: Reporte final ─────────────────────────────────")
    sim = Simulador(construir_linea())
    sim.iniciar(6)
    motor = MotorCiclos(sim, velocidad=0)
    motor.correr_batch()

    rep = Reporte(sim)
    rep.mostrar()

    d = rep.datos
    assert d["productos_completados"] == 6
    assert d["tiempo_primer_producto"] > 0
    assert d["tiempo_ultimo_producto"] >= d["tiempo_primer_producto"]
    assert d["tiempo_promedio"] > 0
    print("  OK — todas las estadísticas calculadas correctamente")


def test_reinicializar():
    print("\n── TEST 5: Reinicializar y volver a correr ───────────────")
    linea = construir_linea()
    sim = Simulador(linea)

    sim.iniciar(3)
    MotorCiclos(sim, velocidad=0).correr_batch()
    ciclos_primera = sim.ciclo_actual
    completados_primera = len(sim.productos_completados)

    # Reinicializar con más productos
    sim.iniciar(6)
    MotorCiclos(sim, velocidad=0).correr_batch()
    ciclos_segunda = sim.ciclo_actual

    assert completados_primera == 3
    assert len(sim.productos_completados) == 6
    assert ciclos_segunda >= ciclos_primera
    print(f"  OK — 1ª corrida: {completados_primera} prods en {ciclos_primera} ciclos")
    print(f"  OK — 2ª corrida: {len(sim.productos_completados)} prods en {ciclos_segunda} ciclos")


if __name__ == "__main__":
    print("\n" + "═"*55)
    print("  SUITE DE PRUEBAS — LinProd Etapa 3")
    print("═"*55)
    test_motor_batch()
    test_breakpoint()
    test_snapshot()
    test_reporte()
    test_reinicializar()
    print("\n" + "═"*55)
    print("  Todos los tests pasaron ✓")
    print("═"*55 + "\n")